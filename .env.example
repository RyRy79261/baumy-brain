# ── Database (Neon) ──────────────────────────────────────────────
DATABASE_URL=                 # pooled (-pooler) connection for app runtime
DATABASE_URL_UNPOOLED=        # direct connection for drizzle-kit migrate

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # from BotFather
TELEGRAM_WEBHOOK_SECRET=      # >=16 chars; sent as X-Telegram-Bot-Api-Secret-Token
BAUMY_HOUSE_CHAT_ID=          # the house group chat_id (negative); the trust boundary
BAUMY_OWNER_ID=               # optional: override the auto-captured inviter

# ── LLM providers ────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # reply / assess / advisor tiers
OPENAI_API_KEY=               # classify (nano) + embeddings

# ── Model routing overrides (optional; defaults in lib/ai/models.ts) ──
# BAUMY_CLASSIFY_MODEL=
# BAUMY_REPLY_MODEL=
# BAUMY_ASSESS_MODEL=
# BAUMY_ADVISOR_MODEL=
# BAUMY_EMBED_MODEL=

# ── Auth / dashboard (Telegram magic-link → signed session; NO Better Auth) ──
BAUMY_SESSION_SECRET=         # >=16 chars; signs the dashboard session cookie
BAUMY_PUBLIC_URL=             # your deployed origin, for the magic links

# ── Crypto (OPTIONAL until the secure-value AES helper is wired) ──
# BAUMY_ENCRYPTION_KEY=       # 32-byte base64; AES-256-GCM for secure_value facts

# ── Ops ──────────────────────────────────────────────────────────
BAUMY_TIMEZONE=Europe/Berlin  # house timezone (IANA)
BAUMY_DAILY_SPEND_CAP=0.5     # USD/day hard cap
# BAUMY_ADMIN_CHAT_ID=        # owner DM chat for cost/health alerts

# ── Inngest (auto-injected by the Vercel↔Inngest integration; do NOT commit) ──
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_DEV=1               # local dev only
